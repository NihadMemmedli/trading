# Application
APP_NAME=crypto-ai-trading-research
APP_ENV=development
LOG_LEVEL=INFO

# Runtime mode
# Current allowed values: research, backtest, paper
# Future values, disabled until later phases: sandbox, live
TRADING_MODE=paper
LIVE_TRADING_ENABLED=false
ORDER_EXECUTION_ENABLED=false
SANDBOX_ORDER_EXECUTION_ENABLED=false
REQUIRE_MANUAL_APPROVAL=true

# Exchange connectivity
EXCHANGE_NAME=
EXCHANGE_USE_SANDBOX=true
EXCHANGE_BASE_URL=
EXCHANGE_SANDBOX_BASE_URL=
EXCHANGE_API_KEY=
EXCHANGE_API_SECRET=
EXCHANGE_API_PASSPHRASE=

# Market universe
QUOTE_CURRENCY=USDT
SYMBOL_ALLOWLIST=BTC/USDT,ETH/USDT,SOL/USDT
SYMBOL_BLOCKLIST=
MAX_SYMBOLS=10

# Data paths
DATA_DIR=./data
RAW_DATA_DIR=./data/raw
PROCESSED_DATA_DIR=./data/processed
REPORTS_DIR=./reports

# Backtesting assumptions
INITIAL_CASH=10000
TAKER_FEE_BPS=10
MAKER_FEE_BPS=5
SLIPPAGE_BPS=5
MAX_POSITION_PCT=10
MAX_PORTFOLIO_DRAWDOWN_PCT=10

# Risk controls
MAX_ORDER_NOTIONAL=100
MAX_DAILY_LOSS_PCT=2
KILL_SWITCH_ENABLED=true
ALLOW_LEVERAGE=false
ALLOW_WITHDRAWALS=false
ALLOW_CUSTODY=false

# AI/model configuration
MODEL_PROVIDER=
MODEL_NAME=
MODEL_API_KEY=
MODEL_TEMPERATURE=0

# Observability
STRUCTURED_LOGS=true
METRICS_ENABLED=false
SENTRY_DSN=

# Local infrastructure
POSTGRES_HOST=localhost
POSTGRES_PORT=55432
POSTGRES_DB=trading
POSTGRES_USER=trading
POSTGRES_PASSWORD=trading
DATABASE_URL=postgresql://trading:trading@localhost:55432/trading
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_URL=redis://localhost:6379/0
